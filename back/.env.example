TOKEN=your_telegram_bot_token
WEB_APP_URL=https://your-domain/
# Публичный адрес бэкенда для server_callback вебхука Fondy (дев: туннель ngrok на :8000).
BACKEND_URL=http://localhost:8000
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/your_db
GEMINI_API_KEY=your_gemini_api_key
SECRET_KEY=change_me_in_production
GOOGLE_CLIENT_ID=your_google_oauth_client_id
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=your_email@gmail.com
TG_BOT_TOKEN=your_telegram_bot_token
# Fondy: тестовый мерчант = 1396424 / test. Боевые получишь после верификации.
FONDY_MERCHANT_ID=1396424
FONDY_MERCHANT_PASSWORD=test
# Валюта списания = валюта студии (онбординг). Fondy рассчитывает в 6 валютах: UAH, EUR, USD, GBP, PLN, CZK (RUB нет). Ниже — дефолт/фолбэк.
FONDY_CURRENCY=UAH
