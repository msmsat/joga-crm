# ==========================================
# 1. Секреты и переменные окружения (САМОЕ ВАЖНОЕ)
# ==========================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem

# ==========================================
# 2. Зависимости (Фронтенд и Бэкенд)
# ==========================================
node_modules/
.npm/

# ==========================================
# 3. Сборка и билды (Vite, React, Бэкенд)
# ==========================================
dist/
dist-ssr/
build/
out/
*.tsbuildinfo

# ==========================================
# 4. Логи и дебаг
# ==========================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ==========================================
# 5. Кэш фреймворков и линтеров
# ==========================================
.eslintcache
.stylelintcache
.vite/
.turbo/
.next/
.nuxt/

# ==========================================
# 6. Тесты и покрытие кода
# ==========================================
coverage/
.nyc_output/

# ==========================================
# 7. Базы данных и медиа (чтобы не пушить мусор)
# ==========================================
*.sqlite
*.sqlite3
*.db
# Если бэкенд будет сохранять картинки юзеров локально при разработке:
uploads/
public/uploads/

# ==========================================
# 8. Системные файлы (macOS, Windows, Linux)
# ==========================================
.DS_Store
.AppleDouble
.LSOverride
Icon
Thumbs.db
ehthumbs.db
Desktop.ini

# ==========================================
# 9. IDE и редакторы кода
# ==========================================
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.swp
*.swo

# ==========================================
# 10. Python (Бэкенд)
# ==========================================
__pycache__/
*.py[cod]
*$py.class

# Виртуальные окружения Python
venv/
.venv/
env/
.env_python/

# Сборки и кэш пакетов Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
parts/
sdist/
var/
wheels/
